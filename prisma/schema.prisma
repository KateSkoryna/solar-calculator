// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  VIEWER
}

enum VehicleType {
  VAN
  TRUCK
  TRAILER
  BUS
}

enum EngineType {
  DIESEL
  PETROL
  ELECTRIC
  HYBRID
}

enum ParkingType {
  DEPOT
  STREET
  CUSTOMER_SITE
  MIXED
}

enum SolarPanelPlacement {
  ROOF
  SIDES
  BACK
  ALL_OVER
}

enum ReportJobStatus {
  QUEUED
  VALIDATING
  CALCULATING
  RENDERING_CHARTS
  GENERATING_REPORT
  GENERATING_RECOMMENDATIONS
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String?
  name             String?
  emailVerified    DateTime?
  image            String?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts     Account[]
  memberships  FleetMembership[]
  calculations Calculation[]
  reportJobs   ReportJob[]
  auditEvents  AuditEvent[]
}

model Fleet {
  id        String      @id @default(cuid())
  name      String
  type      VehicleType
  createdAt DateTime    @default(now())

  memberships  FleetMembership[]
  vehicles     Vehicle[]
  calculations Calculation[]
  reportJobs   ReportJob[]
  auditEvents  AuditEvent[]
  featureFlags FeatureFlag[]
}

model FleetMembership {
  id        String   @id @default(cuid())
  fleetId   String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fleetId, userId])
  @@index([userId])
}

model Vehicle {
  id                           String              @id @default(cuid())
  fleetId                      String
  manufacturer                 String
  model                        String
  vehicleType                  VehicleType
  engineType                   EngineType
  parkingType                  ParkingType
  quantity                     Int
  averageDailyDistanceKm       Float
  energyConsumptionKwhPer100km Float
  solarPanelCapacityKw         Float
  solarPanelPlacement          SolarPanelPlacement
  payloadReserveKg             Float
  maxRoofLoadKg                Float
  operatingMonthsPerYear       Int
  winterUsage                  Boolean
  city                         String
  country                      String
  deletedAt                    DateTime?
  createdAt                    DateTime            @default(now())

  fleet        Fleet         @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  calculations Calculation[]

  @@unique([id, fleetId])
  @@index([fleetId, deletedAt])
}

model Calculation {
  id                String   @id @default(cuid())
  fleetId           String
  vehicleId         String
  requestedByUserId String
  notes             String?
  createdAt         DateTime @default(now())

  fleet           Fleet                @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  vehicle         Vehicle              @relation(fields: [vehicleId, fleetId], references: [id, fleetId], onDelete: Restrict)
  requestedByUser User                 @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  scenario        CalculationScenario?

  @@index([fleetId])
  @@index([vehicleId])
  @@index([requestedByUserId])
}

model CalculationScenario {
  id                   String   @id @default(cuid())
  calculationId        String   @unique
  label                String
  formulaVersion       String
  assumptionSetVersion String
  createdAt            DateTime @default(now())

  calculation   Calculation               @relation(fields: [calculationId], references: [id], onDelete: Cascade)
  inputSnapshot CalculationInputSnapshot?
  result        CalculationResult?
  reportJobs    ReportJob[]
}

model CalculationInputSnapshot {
  id                              String   @id @default(cuid())
  calculationScenarioId           String   @unique
  vehicleSpec                     Json
  energyPriceAssumptionVersion    String
  emissionsFactorVersion          String
  solarYieldAssumptionVersion     String
  currencyConversionSourceVersion String
  capturedAt                      DateTime @default(now())

  scenario CalculationScenario @relation(fields: [calculationScenarioId], references: [id], onDelete: Cascade)
}

model CalculationResult {
  id                    String   @id @default(cuid())
  calculationScenarioId String   @unique
  paybackPeriodMonths   Float
  totalSolarYieldKwh    Float
  co2SavedKg            Float
  netSavingsAmount      Decimal  @db.Decimal(12, 2)
  currency              String
  computedAt            DateTime @default(now())

  scenario CalculationScenario @relation(fields: [calculationScenarioId], references: [id], onDelete: Cascade)
}

model ReportJob {
  id                    String          @id @default(cuid())
  fleetId               String
  calculationScenarioId String
  requestedByUserId     String
  status                ReportJobStatus @default(QUEUED)
  idempotencyKey        String          @unique
  temporalWorkflowId    String          @unique
  fileUrl               String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  fleet               Fleet               @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  calculationScenario CalculationScenario @relation(fields: [calculationScenarioId], references: [id], onDelete: Restrict)
  requestedByUser     User                @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@index([fleetId, status])
  @@index([calculationScenarioId])
  @@index([requestedByUserId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  fleetId     String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadata    Json
  createdAt   DateTime @default(now())

  fleet     Fleet? @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  actorUser User?  @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([fleetId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  fleetId   String?
  key       String
  enabled   Boolean
  payload   Json?
  updatedAt DateTime @updatedAt

  fleet Fleet? @relation(fields: [fleetId], references: [id], onDelete: Restrict)

  @@unique([fleetId, key])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
